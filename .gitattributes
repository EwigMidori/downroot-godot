# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Explicit text files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.godot text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.gd text eol=lf
*.shader text eol=lf
*.cfg text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.svg binary
*.wav binary
*.mp3 binary
*.ogg binary
*.ttf binary
*.otf binary
*.dll binary
*.exe binary

